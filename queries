query CiclosPaciente {
  patientCycles(patientId: "3") {
    cycleNumber
    sessionCount
    firstSessionDate
    lastSessionDate
    therapists {
      firstName
      lastName
    }
    paymentSummary {
      paid
      pending
      exempt
    }
  }
}