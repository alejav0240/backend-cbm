query VerPacientes($search: String = "", $status: String = "") {
  patients(search: $search, status: $status) {
    fullName
    imageUrl
    birthDate
    status
    tutor {
      firstName
      celular
    }
  }
}

query VerSesiones($patientId: ID = "", $paymentStatus: String = "", $sessionType: String = "", $therapistId: ID = "", $sessionStatus: String = "") {
  sessions(
    patientId: $patientId
    therapistId: $therapistId
    paymentStatus: $paymentStatus
    sessionType: $sessionType
    sessionStatus: $sessionStatus
  ) {
    patient {
      fullName
      id
    }
    group {
      name
      id
    }
    videoUrl
    paymentStatus
    paymentStatusDisplay
    cycleNumber
    sessionDate
    sessionStatus
  }
}

