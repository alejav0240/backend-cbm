# - Editar Info Pacinetes
mutation MyMutation($id: ID = "1") {
  updateClinicalNotes(
    authorId: "1"
    patientId: $id
    notes: [{category: "GENERAL_OBJECTIVE", content: "Fomentar la comunicación bidireccional..."}, {category: "PHYSICAL_AREA", content: "Fortalecer la motricidad fina..."}, {category: "EMOTIONAL_AREA", content: "Reducir los niveles de ansiedad..."}, {category: "COGNITIVE_AREA", content: "Mejorar los periodos de atención..."}, {category: "SOCIAL_AREA", content: "Desarrollar el contacto visual..."}, {category: "METHODS", content: "Modelo Nordoff-Robbins..."}, {category: "ADDITIONAL_NOTES", content: "Respuesta excepcional al piano..."}]
  ) {
    notesUpdated {
      category
      content
    }
  }
  updatePatient(
    id: $id
    imageUrl: "https://api.dicebear.com/7.x/avataaars/svg?seed=Felix"
    residence: "Zona Sur, La Paz"
    diagnosis: "Trastorno del Espectro Autista (TEA) - Grado 1"
  ) {
    patient {
      fullName
      diagnosis
      residence
    }
  }
}

